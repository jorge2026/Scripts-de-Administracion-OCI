# Ejemplo de configuración de OCI para los scripts
# Copia este archivo a .env y rellena tus valores

# Configuración de OCI
OCI_CONFIG_PATH=~/.oci/config
OCI_PROFILE=DEFAULT

# IDs de Compartments (reemplaza con tus valores)
COMPARTMENT_ID=ocid1.compartment.oc1..xxxxxxxxxxxxx
COMPARTMENT_NAME=mi-compartment

# IDs de Instancias para pruebas rápidas (opcional)
INSTANCE_ID_1=ocid1.instance.oc1..xxxxxxxxxxxxx
INSTANCE_ID_2=ocid1.instance.oc1..xxxxxxxxxxxxx

# Configuración de Monitoreo
MONITORING_MINUTES=60
MONITORING_INTERVAL=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=oci_scripts.log

# Región (opcional, si se especifica aquí anula la del config)
# OCI_REGION=us-ashburn-1
